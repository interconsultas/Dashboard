# Copia este archivo como .env.local y completa los valores

# ── Base de datos ────────────────────────────
DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_BD

# ── Autenticación ────────────────────────────
NEXTAUTH_SECRET=SECRETO_ALEATORIO_MINIMO_32_CARACTERES
NEXTAUTH_URL=http://localhost:3000

# ── Dashboard ────────────────────────────────
SEMAFORO_VERDE_MIN=80
SEMAFORO_AMARILLO_MIN=60

# ── ETL (rutas al proceso Python) ────────────
PYTHON_PATH=python
ETL_SCRIPT_PATH=../etl/etl_autorizaciones.py
UPLOADS_DIR=../tmp_uploads
ETL_LOGS_DIR=../logs
